name: "JavDB App to SenPlayer"
desc: "适配第三方 JavDB App (域名: tp.cmastd.com)"
tag: "自动化"

# MITM 必须在最顶层，域名建议加上双引号
mitm:
  host:
    - "tp.cmastd.com"

script-providers:
  javdb_app_to_senplayer:
    url: "https://raw.githubusercontent.com/edu001xxk/stashall/refs/heads/main/javdb_app_to_senplayer.js?v=5"
    interval: 86400

http:
  script:
    - match: "^https?:\\/\\/tp\\.cmastd\\.com\\/"
      name: "javdb_app_to_senplayer"
      type: "response"
      require-body: true
      timeout: 10