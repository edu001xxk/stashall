name: "JavDB to SenPlayer"
desc: "抓取 JavDB 番号匹配 Jable 源，并通过通知唤醒 SenPlayer播放器"

script-providers:
  javdb_app_to_senplayer:
    url: https://raw.githubusercontent.com/edu001xxk/stashall/refs/heads/main/javdb_app_to_senplayer.js
    interval: 86400

http:
  script:
    - match: ^https?:\/\/javdb\.com\/v\/
      name: javdb_app_to_senplayer
      type: response
      require-body: true
      timeout: 10

mitm:
  host:
    - javdb.com
